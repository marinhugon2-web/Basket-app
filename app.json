{
  "expo": {
    "name": "Court Forge",
    "slug": "court-forge-dashboard-xp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "courtforge",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.courtforge.dashboardxp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-foreground.png",
        "backgroundColor": "#090A0C"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.courtforge.dashboardxp"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#090A0C",
          "dark": {
            "image": "./assets/splash.png",
            "backgroundColor": "#090A0C"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
